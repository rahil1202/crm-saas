PORT=8787
FRONTEND_URL=https://crm.digoltech.com
BACKEND_URL=https://apicrm.digoltech.com

# ===============================================
# Database
# ===============================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crm_saas

# ===============================================
# Supabase (Auth provider)
# ===============================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_AUDIENCE=authenticated

# ===============================================
# JWT Secrets — MUST be changed in production
# Use: openssl rand -hex 32
# ===============================================
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# IMPORTANT: Keep this separate from ACCESS_TOKEN_SECRET.
# Rotating ACCESS_TOKEN_SECRET will NOT break stored OAuth tokens
# only if INTEGRATION_CRYPTO_SECRET is set independently.
INTEGRATION_CRYPTO_SECRET=

# ===============================================
# Token TTLs
# ===============================================
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# ===============================================
# File storage
# ===============================================
FILE_STORAGE_DIR=storage/uploads
SUPABASE_STORAGE_BUCKET_DOCUMENTS=documents

# ===============================================
# Super admin — comma-separated emails
# These users get platform-wide admin access
# ===============================================
SUPER_ADMIN_EMAILS=

# ===============================================
# Cookie settings
# PRODUCTION: Set COOKIE_SECURE=1 and COOKIE_SAME_SITE=None
# ===============================================
COOKIE_SECURE=1
COOKIE_SAME_SITE=None
COOKIE_DOMAIN=.digoltech.com
AUTH_DEBUG_LOGS=0
AUTH_CALLBACK_URL=https://crm.digoltech.com/auth/callback

# ===============================================
# Background worker
# ===============================================
RUNTIME_WORKER_ENABLED=1
RUNTIME_POLL_INTERVAL_MS=2000

# ===============================================
# Email (Resend — optional system fallback)
# If not set, only per-company OAuth accounts are used for sending.
# ===============================================
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=CRM System

# ===============================================
# WhatsApp (Meta Cloud API)
# ===============================================
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_META_APP_ID=
WHATSAPP_META_APP_SECRET=
WHATSAPP_EMBEDDED_SIGNUP_CONFIG_ID=
WHATSAPP_EMBEDDED_SIGNUP_REDIRECT_URI=https://crm.digoltech.com/dashboard/whatsapp-crm/integrations
WHATSAPP_PHONE_MPS=60
WHATSAPP_PAIR_INTERVAL_SECONDS=6
WHATSAPP_OUTBOX_MAX_ATTEMPTS=5

# ===============================================
# Google OAuth — Gmail outreach connection
# This is NOT the Supabase login OAuth.
# Used to connect Gmail accounts for sending campaigns.
#
# Setup:
#   1. Go to https://console.cloud.google.com/
#   2. Create OAuth 2.0 credentials (Web application)
#   3. Add Authorized redirect URI:
#      https://apicrm.digoltech.com/api/v1/google/callback
#   4. Enable the Gmail API in the project
# ===============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_GMAIL_REDIRECT_URI=https://apicrm.digoltech.com/api/v1/google/callback

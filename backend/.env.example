PORT=8787
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8787
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_AUDIENCE=authenticated
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
FILE_STORAGE_DIR=storage/uploads
SUPER_ADMIN_EMAILS=
COOKIE_SECURE=0
AUTH_CALLBACK_URL=http://localhost:3000/auth/callback
RUNTIME_WORKER_ENABLED=1
RUNTIME_POLL_INTERVAL_MS=2000
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# ===============================================
# WhatsApp (official Meta WhatsApp Cloud API only)
# ===============================================
# Default fallback access token used only when a workspace has no encrypted token
WHATSAPP_ACCESS_TOKEN=
# Default verify token used only when a webhook has no per-workspace key
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Default Meta app secret used to verify x-hub-signature-256 for webhooks without a per-workspace secret
WHATSAPP_APP_SECRET=
# Meta Graph API version used for Cloud API calls
WHATSAPP_GRAPH_API_VERSION=v23.0
# Meta App used for Embedded Signup (System User app)
WHATSAPP_META_APP_ID=
WHATSAPP_META_APP_SECRET=
# Embedded Signup flow configuration from App Dashboard → WhatsApp → Configuration
WHATSAPP_EMBEDDED_SIGNUP_CONFIG_ID=
WHATSAPP_EMBEDDED_SIGNUP_REDIRECT_URI=http://localhost:3000/dashboard/whatsapp-crm/integrations
# Outbound throughput and queue
WHATSAPP_PHONE_MPS=60
WHATSAPP_PAIR_INTERVAL_SECONDS=6
WHATSAPP_OUTBOX_MAX_ATTEMPTS=5

RESEND_API_KEY=""